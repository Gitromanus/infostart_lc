{
  "manifest_version": 3,
  "name": "Инфостарт Курс SM",
  "version": "1.5",
  "permissions": ["storage"],
  "host_permissions": ["https://infostart.ru/*"],
  "content_scripts": [
    {
      "matches": ["https://infostart.ru/profile/money/transact/*"],
      "js": ["content.js"],
      "css": ["theme.css"],
      "run_at": "document_start"
    }
  ]
}
